# Novel-OS 环境变量配置
# 请复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# 主 API Key（支持 DeepSeek、SiliconFlow、Moonshot 等 OpenAI 兼容接口）
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.deepseek.com/v1

# 备用 API Key（当主 Key 失败时自动切换）
OPENAI_API_KEY_FALLBACK=your-fallback-key-here

# 默认模型（可选）
LLM_MODEL=deepseek-chat

# Novel-OS 项目基础路径（可选）
NOVEL_BASE_PATH=D:/noveos/books

# Novel-OS 核心路径（可选）
NOVEL_OS_PATH=D:/noveos/novel-os

# 本地登录凭证（可选，未配置时默认 admin/admin）
NOVEL_OS_USERNAME=admin
NOVEL_OS_PASSWORD=admin
NOVEL_OS_SECRET_KEY=your-secret-key-here
